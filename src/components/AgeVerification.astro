---
---

<div id="age-gate" class="fixed inset-0 z-[60] bg-[var(--color-ink)] text-[var(--color-paper)] flex items-center justify-center" style="display:none">
  <div class="grain absolute inset-0"></div>
  <div class="relative z-10 max-w-xl mx-auto px-6 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.3em] text-sky-400 mb-8">— 年齢確認 —</p>
    <h2 class="font-display text-5xl md:text-7xl font-medium leading-tight mb-6">
      18歳以上ですか？
    </h2>
    <p class="text-neutral-400 text-sm leading-relaxed mb-10 max-w-md mx-auto">
      このサイトは成人向けコンテンツ（音声作品）の情報を含みます。<br />
      18歳以上であることを確認してください。
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button
        id="age-yes"
        class="px-8 py-3.5 bg-[var(--color-paper)] text-[var(--color-ink)] font-medium rounded-full hover:bg-sky-400 transition-colors duration-300 cursor-pointer"
      >
        はい、18歳以上です
      </button>
      <button
        id="age-no"
        class="px-8 py-3.5 border border-neutral-700 text-neutral-300 font-medium rounded-full hover:bg-neutral-900 transition-colors duration-300 cursor-pointer"
      >
        いいえ
      </button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'mt-age-verified-v2';
  const gate = document.getElementById('age-gate')!;
  const verified = localStorage.getItem(STORAGE_KEY);

  if (!verified) {
    gate.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  document.getElementById('age-yes')!.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, '1');
    gate.style.opacity = '0';
    gate.style.transition = 'opacity 0.5s';
    setTimeout(() => {
      gate.style.display = 'none';
      document.body.style.overflow = '';
    }, 500);
  });

  document.getElementById('age-no')!.addEventListener('click', () => {
    window.location.href = 'https://www.google.com';
  });
</script>
