---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink)] text-[var(--color-paper)] relative overflow-hidden">

  <!-- CTA banner -->
  <div class="border-b border-neutral-800 px-5 md:px-10 py-16 md:py-24">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-sky-400 mb-4">— Get in touch</p>
        <h3 class="font-display text-5xl md:text-7xl lg:text-8xl font-medium leading-[0.95] tracking-tight">
          ご相談、<br /><span class="font-serif-it text-sky-400">お待ちしています</span>
        </h3>
      </div>
      <a
        href="/contact"
        class="self-start md:self-end inline-flex items-center gap-3 px-7 py-3.5 bg-[var(--color-paper)] text-[var(--color-ink)] text-sm font-medium rounded-full hover:bg-sky-500 hover:text-white transition-colors duration-300 group whitespace-nowrap"
      >
        依頼・相談する
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="px-5 md:px-10 py-16 md:py-24">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-y-12 gap-x-6">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-5">
        <p class="font-display text-5xl md:text-7xl font-medium leading-none mb-6">
          mike<span class="font-serif-it text-sky-400">tone</span>
        </p>
        <p class="text-neutral-400 text-sm leading-relaxed max-w-xs">
          音声作品の制作を裏側から支える、<br />
          シナリオ・運営・会計の専門サポート。
        </p>
      </div>

      <!-- Index -->
      <div class="col-span-1 md:col-span-3 md:col-start-7">
        <p class="font-mono text-xs text-neutral-500 mb-4 uppercase tracking-widest">ページ</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/services" class="link-underline">Services</a></li>
          <li><a href="/portfolio" class="link-underline">Portfolio</a></li>
          <li><a href="/blog" class="link-underline">Blog</a></li>
          <li><a href="/contact" class="link-underline">Contact</a></li>
        </ul>
      </div>

      <!-- Get in touch -->
      <div class="col-span-1 md:col-span-3">
        <p class="font-mono text-xs text-neutral-500 mb-4 uppercase tracking-widest">お問い合わせ</p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 group text-sm border-b border-neutral-700 pb-1"
        >
          依頼・相談する
          <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>

    <div class="border-t border-neutral-800 mt-16 pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 text-xs text-neutral-500">
      <p>© {year} miketone</p>
      <p class="font-mono">All rights reserved.</p>
    </div>
  </div>
</footer>
