---
const navLinks = [
  { href: '/', label: 'Home', num: '00' },
  { href: '/services', label: 'Services', num: '01' },
  { href: '/portfolio', label: 'Portfolio', num: '02' },
  { href: '/blog', label: 'Blog', num: '03' },
  { href: '/contact', label: 'Contact', num: '04' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-500">
  <div class="px-5 md:px-10 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="flex items-baseline gap-2 group">
      <span class="font-display text-2xl md:text-3xl font-medium tracking-tight">miketone</span>
      <span class="hidden md:inline text-xs text-neutral-500 font-mono">©2026</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label, num }) => (
        <a
          href={href}
          class={`group relative px-4 py-2 text-sm transition-colors ${
            currentPath === href ? 'text-[var(--color-ink)]' : 'text-neutral-500 hover:text-[var(--color-ink)]'
          }`}
        >
          <span class="font-mono text-[10px] mr-1.5 align-top text-neutral-400">{num}</span>
          <span class="link-underline">{label}</span>
          {currentPath === href && (
            <span class="absolute left-4 right-4 -bottom-px h-px bg-[var(--color-ink)]"></span>
          )}
        </a>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden md:inline-flex items-center gap-2 group px-5 py-2.5 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-full hover:bg-sky-500 transition-colors duration-300"
    >
      <span>お問い合わせ</span>
      <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <button id="menu-btn" class="md:hidden p-2 flex flex-col gap-1.5 items-end" aria-label="メニュー">
      <span class="w-6 h-px bg-[var(--color-ink)] transition-all" id="bar1"></span>
      <span class="w-4 h-px bg-[var(--color-ink)] transition-all" id="bar2"></span>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden fixed inset-0 top-16 bg-[var(--color-paper)] hidden">
    <div class="px-5 py-8 flex flex-col">
      {navLinks.map(({ href, label, num }) => (
        <a
          href={href}
          class="group flex items-baseline gap-4 py-5 border-b border-neutral-200"
        >
          <span class="font-mono text-xs text-neutral-400">{num}</span>
          <span class="font-display text-3xl font-medium">{label}</span>
        </a>
      ))}
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center gap-2 px-6 py-4 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-full"
      >
        お問い合わせ
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<div class="h-16 md:h-20"></div>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header.classList.add('bg-[var(--color-paper)]/85', 'backdrop-blur-md', 'border-b', 'border-neutral-200/60');
    } else {
      header.classList.remove('bg-[var(--color-paper)]/85', 'backdrop-blur-md', 'border-b', 'border-neutral-200/60');
    }
  });

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    if (isOpen) {
      mobileMenu.classList.add('hidden');
      document.body.style.overflow = '';
      bar1.style.transform = '';
      bar2.style.transform = '';
      bar2.style.width = '1rem';
    } else {
      mobileMenu.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      bar1.style.transform = 'translateY(3px) rotate(45deg)';
      bar2.style.transform = 'translateY(-3px) rotate(-45deg)';
      bar2.style.width = '1.5rem';
    }
  });
</script>
