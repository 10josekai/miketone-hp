---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-lg tracking-tight text-slate-900">
      mike<span class="text-sky-500">tone</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm font-medium transition-colors duration-200 ${
            currentPath === href
              ? 'text-sky-500'
              : 'text-slate-600 hover:text-sky-500'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden md:inline-flex items-center px-4 py-2 bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold rounded-lg transition-colors duration-200"
    >
      依頼する
    </a>

    <button id="menu-btn" class="md:hidden p-2 text-slate-600" aria-label="メニュー">
      <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-slate-100 shadow-lg">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="text-sm font-medium text-slate-700 hover:text-sky-500 transition-colors py-1">
          {label}
        </a>
      ))}
      <a href="/contact" class="inline-flex items-center justify-center px-4 py-2 bg-sky-500 text-white text-sm font-semibold rounded-lg mt-2">
        依頼する
      </a>
    </div>
  </div>
</header>

<div class="h-16"></div>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-slate-100');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-slate-100');
    }
  });

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });
</script>
