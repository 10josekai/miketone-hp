---
---

<div id="hero-3d" class="absolute inset-0 pointer-events-none">
  <canvas id="hero-canvas" class="w-full h-full"></canvas>
</div>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const container = canvas.parentElement!;
    let width = container.clientWidth;
    let height = container.clientHeight;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, width / height, 0.1, 100);
    camera.position.z = 6;

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(width, height, false);
    renderer.setClearColor(0x000000, 0);

    // ===== Main central sphere (audio wave inspired) =====
    const sphereGeo = new THREE.IcosahedronGeometry(1.6, 32);
    const basePositions = sphereGeo.attributes.position.array.slice();

    const sphereMaterial = new THREE.MeshBasicMaterial({
      color: 0x0ea5e9,
      wireframe: true,
      transparent: true,
      opacity: 0.5,
    });
    const sphere = new THREE.Mesh(sphereGeo, sphereMaterial);
    sphere.position.set(1.8, 0, 0);
    scene.add(sphere);

    // Inner glowing sphere
    const innerSphereGeo = new THREE.IcosahedronGeometry(0.6, 4);
    const innerMaterial = new THREE.MeshBasicMaterial({
      color: 0x0a0a0a,
      transparent: true,
      opacity: 0.85,
    });
    const innerSphere = new THREE.Mesh(innerSphereGeo, innerMaterial);
    sphere.add(innerSphere);

    // ===== Floating shapes (B) =====
    const floatingShapes: THREE.Mesh[] = [];

    // Torus 1
    const torusGeo = new THREE.TorusGeometry(0.5, 0.04, 16, 80);
    const torusMat = new THREE.MeshBasicMaterial({
      color: 0x0a0a0a,
      wireframe: false,
      transparent: true,
      opacity: 0.4,
    });
    const torus = new THREE.Mesh(torusGeo, torusMat);
    torus.position.set(-2.2, 1.2, 0.5);
    torus.rotation.x = Math.PI / 4;
    scene.add(torus);
    floatingShapes.push(torus);

    // Small icosahedron 1
    const ico1Geo = new THREE.IcosahedronGeometry(0.25, 0);
    const ico1Mat = new THREE.MeshBasicMaterial({
      color: 0x0ea5e9,
      wireframe: true,
      transparent: true,
      opacity: 0.8,
    });
    const ico1 = new THREE.Mesh(ico1Geo, ico1Mat);
    ico1.position.set(-1.5, -1.4, 1);
    scene.add(ico1);
    floatingShapes.push(ico1);

    // Ring 2
    const ringGeo = new THREE.RingGeometry(0.3, 0.32, 64);
    const ringMat = new THREE.MeshBasicMaterial({
      color: 0x0a0a0a,
      side: THREE.DoubleSide,
      transparent: true,
      opacity: 0.5,
    });
    const ring = new THREE.Mesh(ringGeo, ringMat);
    ring.position.set(3.2, -1.2, 0.5);
    ring.rotation.x = Math.PI / 3;
    scene.add(ring);
    floatingShapes.push(ring);

    // Small dot sphere
    const dotGeo = new THREE.IcosahedronGeometry(0.1, 2);
    const dotMat = new THREE.MeshBasicMaterial({ color: 0x0ea5e9 });
    const dot = new THREE.Mesh(dotGeo, dotMat);
    dot.position.set(0.5, 1.8, 0.5);
    scene.add(dot);
    floatingShapes.push(dot);

    // Mouse
    const mouse = { x: 0, y: 0, tx: 0, ty: 0 };
    window.addEventListener('mousemove', (e) => {
      mouse.tx = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.ty = -(e.clientY / window.innerHeight - 0.5) * 2;
    });

    // Animate
    const clock = new THREE.Clock();
    let frame = 0;

    function animate() {
      const t = clock.getElapsedTime();
      frame = requestAnimationFrame(animate);

      // Smooth mouse
      mouse.x += (mouse.tx - mouse.x) * 0.05;
      mouse.y += (mouse.ty - mouse.y) * 0.05;

      // Distort main sphere
      const positions = sphere.geometry.attributes.position.array as Float32Array;
      for (let i = 0; i < positions.length; i += 3) {
        const ox = basePositions[i];
        const oy = basePositions[i + 1];
        const oz = basePositions[i + 2];
        const dist = Math.sqrt(ox * ox + oy * oy + oz * oz);
        const noise =
          Math.sin(ox * 2 + t * 0.8) * 0.06 +
          Math.cos(oy * 3 + t * 0.6) * 0.05 +
          Math.sin(oz * 2.5 + t * 0.9) * 0.04;
        const factor = 1 + noise + mouse.x * 0.08;
        positions[i] = ox * factor;
        positions[i + 1] = oy * factor;
        positions[i + 2] = oz * factor;
      }
      sphere.geometry.attributes.position.needsUpdate = true;
      sphere.geometry.computeVertexNormals();

      sphere.rotation.y = t * 0.12 + mouse.x * 0.3;
      sphere.rotation.x = mouse.y * 0.3;

      // Float other shapes
      torus.rotation.x = Math.PI / 4 + t * 0.2;
      torus.rotation.y = t * 0.15;
      torus.position.y = 1.2 + Math.sin(t * 0.8) * 0.15;

      ico1.rotation.x = t * 0.4;
      ico1.rotation.y = t * 0.3;
      ico1.position.y = -1.4 + Math.cos(t * 0.9) * 0.2;

      ring.rotation.z = t * 0.3;
      ring.position.x = 3.2 + Math.sin(t * 0.6) * 0.15;

      dot.position.y = 1.8 + Math.sin(t * 1.2) * 0.3;
      dot.position.x = 0.5 + Math.cos(t * 1.0) * 0.2;

      // Camera follow mouse very subtle
      camera.position.x = mouse.x * 0.3;
      camera.position.y = mouse.y * 0.2;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }

    // Resize
    function onResize() {
      width = container.clientWidth;
      height = container.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height, false);
    }
    window.addEventListener('resize', onResize);

    // Visibility-based pause for performance
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          if (!frame) animate();
        } else {
          cancelAnimationFrame(frame);
          frame = 0;
        }
      });
    });
    io.observe(container);

    animate();
  }
</script>
