---
---

<div id="hero-3d" class="absolute inset-0 pointer-events-none overflow-hidden">
  <canvas id="hero-canvas" class="w-full h-full"></canvas>
</div>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const container = canvas.parentElement!;
    let width = container.clientWidth;
    let height = container.clientHeight;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, width / height, 0.1, 100);
    camera.position.z = 7;

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(width, height, false);
    renderer.setClearColor(0x000000, 0);

    // Colors
    const COLOR_SKY = 0x0ea5e9;
    const COLOR_SKY_LIGHT = 0x7dd3fc;
    const COLOR_AMBER = 0xfbbf24;
    const COLOR_INK = 0x0a0a0a;

    type FloatingShape = {
      mesh: THREE.Object3D;
      basePos: THREE.Vector3;
      floatSpeed: number;
      floatAmp: number;
      rotSpeed: THREE.Vector3;
      phase: number;
    };

    const shapes: FloatingShape[] = [];

    function addShape(
      mesh: THREE.Object3D,
      pos: [number, number, number],
      floatSpeed = 0.6,
      floatAmp = 0.2,
      rotSpeed: [number, number, number] = [0.1, 0.15, 0.05]
    ) {
      mesh.position.set(...pos);
      scene.add(mesh);
      shapes.push({
        mesh,
        basePos: new THREE.Vector3(...pos),
        floatSpeed,
        floatAmp,
        rotSpeed: new THREE.Vector3(...rotSpeed),
        phase: Math.random() * Math.PI * 2,
      });
    }

    // 1. Top right — wireframe icosahedron (sky)
    const ico1 = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.55, 1),
      new THREE.MeshBasicMaterial({
        color: COLOR_SKY,
        wireframe: true,
        transparent: true,
        opacity: 0.6,
      })
    );
    addShape(ico1, [3.4, 2.0, 0], 0.5, 0.25, [0.12, 0.18, 0.05]);

    // 2. Bottom left — wireframe icosahedron larger (sky)
    const ico2 = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.7, 1),
      new THREE.MeshBasicMaterial({
        color: COLOR_SKY,
        wireframe: true,
        transparent: true,
        opacity: 0.55,
      })
    );
    addShape(ico2, [-3.6, -1.6, 0.5], 0.55, 0.3, [0.08, 0.14, 0.06]);

    // 3. Solid small sphere — amber accent (top left subtle)
    const amberDot = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.14, 3),
      new THREE.MeshBasicMaterial({ color: COLOR_AMBER })
    );
    addShape(amberDot, [-2.2, 1.6, 0.8], 0.8, 0.35, [0, 0, 0]);

    // 4. Ring — ink color, tilted (right side mid)
    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(0.42, 0.012, 16, 80),
      new THREE.MeshBasicMaterial({
        color: COLOR_INK,
        transparent: true,
        opacity: 0.7,
      })
    );
    ring.rotation.x = Math.PI / 2.5;
    addShape(ring, [3.0, -0.2, 0.4], 0.45, 0.18, [0.2, 0.25, 0.08]);

    // 5. Small wireframe sphere (sky light) — middle floating
    const sphere = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.28, 2),
      new THREE.MeshBasicMaterial({
        color: COLOR_SKY_LIGHT,
        wireframe: true,
        transparent: true,
        opacity: 0.55,
      })
    );
    addShape(sphere, [1.5, 2.2, -0.5], 0.7, 0.4, [0.15, 0.2, 0]);

    // 6. Tiny solid sphere — sky-500 dot
    const skyDot = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.08, 2),
      new THREE.MeshBasicMaterial({ color: COLOR_SKY })
    );
    addShape(skyDot, [-1.3, -2.3, 1], 1.0, 0.5, [0, 0, 0]);

    // 7. Open ring small (amber) — accent
    const accentRing = new THREE.Mesh(
      new THREE.TorusGeometry(0.18, 0.008, 12, 48),
      new THREE.MeshBasicMaterial({
        color: COLOR_AMBER,
        transparent: true,
        opacity: 0.85,
      })
    );
    accentRing.rotation.x = Math.PI / 3;
    addShape(accentRing, [-3.0, 0.6, -0.2], 0.6, 0.25, [0.18, 0.22, 0.05]);

    // Mouse parallax
    const mouse = { x: 0, y: 0, tx: 0, ty: 0 };
    window.addEventListener('mousemove', (e) => {
      mouse.tx = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.ty = -(e.clientY / window.innerHeight - 0.5) * 2;
    });

    // Animation
    const clock = new THREE.Clock();
    let frame = 0;

    function animate() {
      const t = clock.getElapsedTime();
      frame = requestAnimationFrame(animate);

      mouse.x += (mouse.tx - mouse.x) * 0.04;
      mouse.y += (mouse.ty - mouse.y) * 0.04;

      shapes.forEach((s) => {
        // Float up/down with sine wave
        s.mesh.position.y = s.basePos.y + Math.sin(t * s.floatSpeed + s.phase) * s.floatAmp;
        s.mesh.position.x = s.basePos.x + Math.cos(t * s.floatSpeed * 0.8 + s.phase) * s.floatAmp * 0.5;
        // Rotation
        s.mesh.rotation.x += s.rotSpeed.x * 0.01;
        s.mesh.rotation.y += s.rotSpeed.y * 0.01;
        s.mesh.rotation.z += s.rotSpeed.z * 0.01;
      });

      // Subtle camera parallax
      camera.position.x = mouse.x * 0.4;
      camera.position.y = mouse.y * 0.25;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }

    function onResize() {
      width = container.clientWidth;
      height = container.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height, false);
    }
    window.addEventListener('resize', onResize);

    // Pause when off-screen
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          if (!frame) animate();
        } else {
          cancelAnimationFrame(frame);
          frame = 0;
        }
      });
    });
    io.observe(container);

    animate();
  }
</script>
