---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>

  <article class="px-5 md:px-10 pt-12 md:pt-20 pb-24">

    <!-- Back link -->
    <a href="/blog" class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-neutral-500 hover:text-sky-500 transition-colors mb-12 reveal">
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none">
        <path d="M13 8H3m0 0l4-4m-4 4l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to Journal
    </a>

    <!-- Meta -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-12 md:mb-20">
      <div class="md:col-span-3 reveal">
        <p class="font-mono text-xs uppercase tracking-widest text-sky-600 mb-2">{post.data.category}</p>
        <p class="font-mono text-xs text-neutral-500">{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      </div>
      <div class="md:col-span-9 reveal reveal-d1">
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-medium leading-[1.05] tracking-tight mb-6">
          {post.data.title}
        </h1>
        <p class="text-lg md:text-xl text-neutral-600 leading-relaxed max-w-2xl">
          {post.data.description}
        </p>
      </div>
    </div>

    <!-- Body -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 border-t border-neutral-200 pt-12">
      <div class="md:col-span-7 md:col-start-4 prose prose-neutral prose-lg max-w-none
        prose-headings:font-display prose-headings:font-medium prose-headings:tracking-tight
        prose-h2:text-3xl md:prose-h2:text-4xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-neutral-700 prose-p:leading-relaxed
        prose-a:text-sky-600 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-[var(--color-ink)]
        prose-code:bg-neutral-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
        prose-blockquote:border-l-sky-500 prose-blockquote:not-italic
        reveal reveal-d2">
        <Content />
      </div>
    </div>

    <!-- Footer -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mt-24 pt-12 border-t border-neutral-200">
      <div class="md:col-span-7 md:col-start-4 reveal">
        <p class="font-display text-3xl md:text-4xl font-medium mb-4">
          ご相談、<span class="font-serif-it text-sky-500">お気軽に</span>。
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-full hover:bg-sky-500 transition-colors duration-300 group mt-2"
        >
          依頼・相談する
          <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </article>

</Layout>
