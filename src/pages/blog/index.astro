---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PageShapes from '../../components/PageShapes.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Journal" description="miketone Journal — 制作の裏話・ノウハウ・確定申告トピック">

  <!-- Hero -->
  <section class="relative px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24 overflow-hidden">
    <PageShapes variant="blog" />
    <div class="relative z-10 flex justify-between items-center mb-12 md:mb-20 text-xs font-mono uppercase tracking-widest text-neutral-500">
      <span>— 03 / Blog</span>
      <span>{posts.length} entries</span>
    </div>
    <h1 class="relative z-10 font-display text-[15vw] md:text-[11vw] lg:text-[9rem] font-medium leading-[0.92] tracking-tight mb-8">
      <span class="mask-reveal block"><span>ブログ</span></span>
      <span class="mask-reveal block"><span><span class="font-serif-it text-sky-500">記事</span></span></span>
    </h1>
    <div class="relative z-10 md:max-w-2xl md:ml-auto reveal reveal-d2">
      <p class="text-neutral-700 text-base md:text-lg leading-relaxed jp-balance">
        制作の裏話、運営のノウハウ、確定申告のヒントなど。<br />現場で見つけた小さな知見を発信しています。
      </p>
    </div>
  </section>

  {posts.length === 0 ? (
    <div class="px-5 md:px-10 py-24 text-center">
      <p class="font-display text-4xl text-neutral-400 font-serif-it">準備中 —</p>
    </div>
  ) : (
    <section class="border-t border-[var(--color-ink)]">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class={`group block border-b border-neutral-200 hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-500 reveal reveal-d${(i % 4) + 1}`}
        >
          <div class="px-5 md:px-10 py-8 md:py-10 grid grid-cols-12 gap-x-4 gap-y-3 items-center">
            <span class="col-span-2 md:col-span-1 font-mono text-xs text-neutral-400 group-hover:text-sky-400 transition-colors">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="col-span-10 md:col-span-7">
              <p class="font-mono text-[10px] uppercase tracking-widest text-sky-600 group-hover:text-sky-400 transition-colors mb-2">
                {post.data.category}
              </p>
              <h2 class="font-display text-2xl md:text-3xl font-medium leading-snug">
                {post.data.title}
              </h2>
            </div>
            <p class="hidden md:block md:col-span-3 text-sm text-neutral-500 group-hover:text-neutral-300 transition-colors leading-relaxed line-clamp-2">
              {post.data.description}
            </p>
            <div class="col-span-12 md:col-span-1 md:text-right">
              <span class="font-mono text-xs text-neutral-400 group-hover:text-neutral-300 transition-colors">
                {post.data.pubDate.toLocaleDateString('ja-JP', { year: '2-digit', month: '2-digit', day: '2-digit' })}
              </span>
            </div>
          </div>
          <p class="md:hidden px-5 pb-6 -mt-2 text-sm text-neutral-500 group-hover:text-neutral-300 transition-colors">
            {post.data.description}
          </p>
        </a>
      ))}
    </section>
  )}

</Layout>
