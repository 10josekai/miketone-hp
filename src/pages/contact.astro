---
import Layout from '../layouts/Layout.astro';
import PageShapes from '../components/PageShapes.astro';
---

<Layout title="Contact" description="miketone — 依頼・相談はこちら">

  <section class="relative px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24 overflow-hidden">
    <PageShapes variant="contact" />
    <div class="relative z-10 flex justify-between items-center mb-12 md:mb-20 text-xs font-mono uppercase tracking-widest text-neutral-500">
      <span>— 04 / Contact</span>
      <span>2〜3営業日以内に返信</span>
    </div>
    <h1 class="relative z-10 font-display text-[15vw] md:text-[11vw] lg:text-[9rem] font-medium leading-[0.92] tracking-tight mb-8">
      <span class="mask-reveal block"><span>お問い</span></span>
      <span class="mask-reveal block"><span><span class="font-serif-it text-sky-500">合わせ</span></span></span>
    </h1>
    <div class="relative z-10 md:max-w-2xl md:ml-auto reveal reveal-d2">
      <p class="text-neutral-700 text-base md:text-lg leading-relaxed jp-balance">
        依頼内容・ご質問・お見積もり相談など、お気軽にどうぞ。<br />通常2〜3営業日以内にご返信します。
      </p>
    </div>
  </section>

  <!-- Notice -->
  <section class="px-5 md:px-10 mb-12">
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 md:p-6 text-sm text-amber-900 reveal flex items-start gap-3">
      <span class="font-mono text-xs uppercase tracking-widest text-amber-700 shrink-0 pt-0.5">Notice —</span>
      <p>確定申告補助はご契約者様向けのプラスサポートのため、お問い合わせでは原則受け付けておりません。シナリオ制作・運営サポートからご相談ください。</p>
    </div>
  </section>

  <!-- Form -->
  <section class="px-5 md:px-10 pb-24 md:pb-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <div class="md:col-span-4 reveal">
        <p class="font-mono text-xs uppercase tracking-widest text-neutral-500 mb-4">— フォーム</p>
        <p class="font-display text-3xl md:text-4xl font-medium leading-tight mb-6 jp-balance">
          入力項目は<br /><span class="font-serif-it text-sky-500">5つ</span>
        </p>
        <ul class="space-y-3 text-sm text-neutral-600">
          <li class="flex gap-3">
            <span class="font-mono text-xs text-sky-600">01</span>
            お名前・サークル名
          </li>
          <li class="flex gap-3">
            <span class="font-mono text-xs text-sky-600">02</span>
            メールアドレス
          </li>
          <li class="flex gap-3">
            <span class="font-mono text-xs text-sky-600">03</span>
            依頼内容のカテゴリ
          </li>
          <li class="flex gap-3">
            <span class="font-mono text-xs text-sky-600">04</span>
            ご相談・依頼の詳細
          </li>
          <li class="flex gap-3">
            <span class="font-mono text-xs text-sky-600">05</span>
            送信！
          </li>
        </ul>
      </div>

      <div class="md:col-span-7 md:col-start-6 reveal reveal-d1">
        <form
          id="contact-form"
          class="space-y-8"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="miketone お問い合わせ" />
          <input type="hidden" name="from_name" value="miketone Contact Form" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="border-b border-neutral-300 focus-within:border-[var(--color-ink)] transition-colors pb-2">
            <label for="name" class="block text-xs font-mono uppercase tracking-widest text-neutral-500 mb-2">
              01 — お名前 / サークル名 <span class="text-sky-500">*</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="例：◯◯サークル / 山田太郎"
              class="w-full bg-transparent text-lg md:text-xl outline-none placeholder:text-neutral-300"
            />
          </div>

          <div class="border-b border-neutral-300 focus-within:border-[var(--color-ink)] transition-colors pb-2">
            <label for="email" class="block text-xs font-mono uppercase tracking-widest text-neutral-500 mb-2">
              02 — メールアドレス <span class="text-sky-500">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="example@mail.com"
              class="w-full bg-transparent text-lg md:text-xl outline-none placeholder:text-neutral-300"
            />
          </div>

          <div class="border-b border-neutral-300 focus-within:border-[var(--color-ink)] transition-colors pb-2">
            <label for="service" class="block text-xs font-mono uppercase tracking-widest text-neutral-500 mb-2">
              03 — 依頼内容 <span class="text-sky-500">*</span>
            </label>
            <select
              id="service"
              name="service"
              required
              class="w-full bg-transparent text-lg md:text-xl outline-none appearance-none"
            >
              <option value="">選択してください</option>
              <option value="scenario">シナリオ制作</option>
              <option value="management">サークル運営補助・連絡代行</option>
              <option value="contracted-tax">確定申告補助の追加相談（既存ご契約者様）</option>
              <option value="other">その他・複数サービス</option>
            </select>
          </div>

          <div class="border-b border-neutral-300 focus-within:border-[var(--color-ink)] transition-colors pb-2">
            <label for="message" class="block text-xs font-mono uppercase tracking-widest text-neutral-500 mb-2">
              04 — ご相談・依頼の詳細 <span class="text-sky-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="依頼内容・ご質問の詳細をお書きください"
              class="w-full bg-transparent text-base md:text-lg outline-none placeholder:text-neutral-300 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-3 py-5 bg-[var(--color-ink)] text-[var(--color-paper)] font-medium rounded-full hover:bg-sky-500 transition-colors duration-300 group"
          >
            <span class="font-mono text-xs uppercase tracking-widest opacity-60">05 →</span>
            送信する
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <p class="text-xs text-neutral-400 text-center font-mono">
            送信内容は依頼・相談対応のみに使用します。
          </p>
        </form>

        <div id="form-success" class="hidden py-16 reveal">
          <p class="font-mono text-xs uppercase tracking-widest text-sky-500 mb-4">— 送信完了</p>
          <p class="font-display text-4xl md:text-5xl font-medium mb-4 jp-balance">
            ありがとうございます
          </p>
          <p class="text-neutral-500">2〜3営業日以内にご返信いたします。</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: data,
    });
    if (res.ok) {
      form.style.display = 'none';
      success.classList.remove('hidden');
      success.classList.add('visible');
    }
  });
</script>
