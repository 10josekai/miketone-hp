---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="miketone へのお問い合わせ・依頼はこちら">

  <div class="max-w-2xl mx-auto px-6 py-20">

    <div class="text-center mb-12 fade-in">
      <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-2">Contact</p>
      <h1 class="text-4xl font-bold text-slate-900 mb-4">お問い合わせ</h1>
      <p class="text-slate-500 leading-relaxed">
        依頼・相談はフォームよりお気軽にどうぞ。<br />
        通常2〜3営業日以内にご返信します。
      </p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800 mb-8 fade-in">
      確定申告・会計補助は<strong>個人の方のみ</strong>対応しています。法人・サークルからのご依頼は連絡代行・運営補助のみ承ります。
    </div>

    <form
      id="contact-form"
      class="space-y-6 fade-in fade-in-delay-1"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
      <input type="hidden" name="subject" value="miketone お問い合わせ" />
      <input type="hidden" name="from_name" value="miketone Contact Form" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

      <div>
        <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">お名前 / サークル名 <span class="text-red-400">*</span></label>
        <input
          id="name"
          name="name"
          type="text"
          required
          placeholder="例：○○サークル / 山田太郎"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 outline-none transition-all text-slate-900 placeholder-slate-400"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">メールアドレス <span class="text-red-400">*</span></label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="example@mail.com"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 outline-none transition-all text-slate-900 placeholder-slate-400"
        />
      </div>

      <div>
        <label for="service" class="block text-sm font-semibold text-slate-700 mb-2">依頼内容 <span class="text-red-400">*</span></label>
        <select
          id="service"
          name="service"
          required
          class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 outline-none transition-all text-slate-900 bg-white"
        >
          <option value="">選択してください</option>
          <option value="scenario">シナリオ制作</option>
          <option value="management">サークル運営補助・連絡代行</option>
          <option value="tax">確定申告・会計ソフト操作補助（個人のみ）</option>
          <option value="other">その他・複数サービス</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">お問い合わせ内容 <span class="text-red-400">*</span></label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          placeholder="依頼内容・ご質問の詳細をお書きください"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 outline-none transition-all text-slate-900 placeholder-slate-400 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-4 bg-sky-500 hover:bg-sky-600 text-white font-bold rounded-xl transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-sky-500/20"
      >
        送信する
      </button>

      <p class="text-xs text-slate-400 text-center">
        送信いただいた内容は依頼・相談対応のみに使用します。
      </p>
    </form>

    <div id="form-success" class="hidden text-center py-12 fade-in">
      <div class="w-16 h-16 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-slate-900 mb-2">送信しました</h2>
      <p class="text-slate-500 text-sm">2〜3営業日以内にご返信いたします。</p>
    </div>

  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: data,
    });
    if (res.ok) {
      form.style.display = 'none';
      success.classList.remove('hidden');
      success.classList.add('visible');
    }
  });
</script>
