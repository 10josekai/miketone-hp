---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestWorks = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Layout title="Home" description="miketone | 音声作品シナリオ制作・サークル運営補助・確定申告補助">

  <!-- Hero -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden bg-gradient-to-br from-slate-50 to-sky-50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-10 w-72 h-72 bg-sky-400/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-10 w-96 h-96 bg-sky-300/10 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-24 relative z-10">
      <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-4 fade-in">Scenario / Management / Consulting</p>
      <h1 class="text-4xl md:text-6xl font-bold text-slate-900 leading-tight mb-6 fade-in fade-in-delay-1">
        音声作品の制作を、<br />
        <span class="text-sky-500">もっとスムーズに。</span>
      </h1>
      <p class="text-slate-600 text-lg md:text-xl max-w-xl leading-relaxed mb-10 fade-in fade-in-delay-2">
        シナリオ制作からサークル運営補助まで。<br />
        あなたの制作活動を、裏側からサポートします。
      </p>
      <div class="flex flex-wrap gap-4 fade-in fade-in-delay-3">
        <a
          href="/services"
          class="inline-flex items-center px-6 py-3 bg-sky-500 hover:bg-sky-600 text-white font-semibold rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-sky-500/20"
        >
          サービスを見る
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/portfolio"
          class="inline-flex items-center px-6 py-3 bg-white hover:bg-slate-50 text-slate-700 font-semibold rounded-xl transition-all duration-200 hover:scale-105 border border-slate-200 shadow-sm"
        >
          作品を見る
        </a>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-2">Services</p>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900">できること</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group p-8 rounded-2xl border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 fade-in fade-in-delay-1">
          <div class="w-12 h-12 bg-sky-50 group-hover:bg-sky-100 rounded-xl flex items-center justify-center mb-5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">シナリオ制作</h3>
          <p class="text-slate-500 text-sm leading-relaxed">DLSiteの成人男性向け音声作品シナリオを専門に制作。ジャンル・設定に合わせた台本を提供します。</p>
          <a href="/services#scenario" class="inline-flex items-center mt-4 text-sky-500 text-sm font-medium hover:underline">
            詳しく見る
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="group p-8 rounded-2xl border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 fade-in fade-in-delay-2">
          <div class="w-12 h-12 bg-sky-50 group-hover:bg-sky-100 rounded-xl flex items-center justify-center mb-5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">サークル運営補助<span class="text-sky-500 text-xs ml-1 font-normal">メイン</span></h3>
          <p class="text-slate-500 text-sm leading-relaxed">マネジメント・タスク管理・連絡代行など、サークル運営に関わる業務を幅広くサポートします。</p>
          <a href="/services#management" class="inline-flex items-center mt-4 text-sky-500 text-sm font-medium hover:underline">
            詳しく見る
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="group p-8 rounded-2xl border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 fade-in fade-in-delay-3">
          <div class="w-12 h-12 bg-sky-50 group-hover:bg-sky-100 rounded-xl flex items-center justify-center mb-5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">確定申告・会計補助<span class="text-slate-400 text-xs ml-1 font-normal">オプション</span></h3>
          <p class="text-slate-500 text-sm leading-relaxed">個人クリエイター向けに確定申告・会計ソフト操作を補助。50名以上のサポート実績があります。</p>
          <a href="/services#tax" class="inline-flex items-center mt-4 text-sky-500 text-sm font-medium hover:underline">
            詳しく見る
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest works -->
  {latestWorks.length > 0 && (
    <section class="py-24 bg-slate-50">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12 fade-in">
          <div>
            <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-2">Portfolio</p>
            <h2 class="text-3xl font-bold text-slate-900">担当作品</h2>
          </div>
          <a href="/portfolio" class="text-sky-500 text-sm font-medium hover:underline hidden sm:block">すべて見る →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
          {latestWorks.map((work, i) => (
            <a
              href={work.data.dlsiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class={`group block bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 hover:-translate-y-1 fade-in fade-in-delay-${i + 1}`}
            >
              <div class="aspect-square overflow-hidden bg-slate-100">
                <img
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-4">
                <p class="text-xs text-sky-500 font-medium mb-1">{work.data.circle}</p>
                <h3 class="text-sm font-bold text-slate-900 line-clamp-2 mb-2">{work.data.title}</h3>
                <p class="text-xs text-slate-500 line-clamp-3">{work.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest blog -->
  {latestPosts.length > 0 && (
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12 fade-in">
          <div>
            <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-2">Blog</p>
            <h2 class="text-3xl font-bold text-slate-900">最新記事</h2>
          </div>
          <a href="/blog" class="text-sky-500 text-sm font-medium hover:underline hidden sm:block">すべて見る →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class={`group block p-6 rounded-2xl border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 hover:-translate-y-1 fade-in fade-in-delay-${i + 1}`}
            >
              <span class="inline-block px-2.5 py-0.5 bg-sky-50 text-sky-600 text-xs font-medium rounded-full mb-3">{post.data.category}</span>
              <h3 class="font-bold text-slate-900 mb-2 line-clamp-2 group-hover:text-sky-600 transition-colors">{post.data.title}</h3>
              <p class="text-slate-500 text-sm line-clamp-2">{post.data.description}</p>
              <p class="text-xs text-slate-400 mt-3">{post.data.pubDate.toLocaleDateString('ja-JP')}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-24 bg-sky-500">
    <div class="max-w-3xl mx-auto px-6 text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        まずはお気軽にご相談ください
      </h2>
      <p class="text-sky-100 text-lg mb-8">
        依頼内容の確認から見積もりまで、無料でご対応します。
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-white hover:bg-sky-50 text-sky-600 font-bold rounded-xl transition-all duration-200 hover:scale-105 shadow-xl"
      >
        お問い合わせ・依頼する
      </a>
    </div>
  </section>

</Layout>
