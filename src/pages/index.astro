---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Hero3D from '../components/Hero3D.astro';


const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestWorks = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Layout title="Index" description="miketone — 音声作品シナリオ制作・サークル運営補助・確定申告補助">

  <!-- ====== HERO ====== -->
  <section class="relative px-5 md:px-10 pt-12 md:pt-24 pb-24 md:pb-32 overflow-hidden">
    <Hero3D />

    <!-- top meta line -->
    <div class="relative z-10 flex justify-between items-center mb-12 md:mb-20 text-xs font-mono uppercase tracking-widest text-neutral-500">
      <span>— 依頼受付中</span>
      <span class="hidden sm:inline">Tokyo / Japan</span>
    </div>

    <!-- Massive headline -->
    <div class="relative z-10">
      <h1 class="font-display text-[18vw] md:text-[14vw] lg:text-[11rem] font-medium leading-[0.92] tracking-tight">
        <span class="mask-reveal block"><span>音声作品の</span></span>
        <span class="mask-reveal block"><span><span class="font-serif-it text-sky-500">制作サポート</span></span></span>
      </h1>
    </div>

    <div class="relative z-10 grid grid-cols-1 md:grid-cols-12 gap-6 mt-12 md:mt-16">
      <div class="md:col-span-5 md:col-start-7 reveal reveal-d2">
        <p class="text-neutral-700 text-base md:text-lg leading-relaxed mb-8 jp-balance">
          DLSiteで販売する成人男性向け音声作品のシナリオ制作と、サークル運営のマネジメント・連絡代行を中心に、制作の裏側をサポートしています。
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/services"
            class="inline-flex items-center gap-2 px-6 py-3.5 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-full hover:bg-sky-500 transition-colors duration-300 group"
          >
            <span class="font-mono text-[10px] opacity-60">→ 01</span>
            サービスを見る
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-6 py-3.5 border border-[var(--color-ink)] text-sm font-medium rounded-full hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-300"
          >
            依頼・相談する
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-5 md:left-10 hidden md:flex items-center gap-3 text-xs font-mono text-neutral-400 z-10">
      <span class="w-12 h-px bg-neutral-400"></span>
      <span>SCROLL</span>
    </div>
  </section>

  <!-- ====== MARQUEE ====== -->
  <section class="border-y border-neutral-200 py-5 md:py-6 overflow-hidden bg-[var(--color-paper)]">
    <div class="marquee items-center">
      {Array.from({ length: 8 }).map(() => (
        <span class="flex items-center gap-8 md:gap-12 pr-8 md:pr-12 text-xl md:text-3xl font-display whitespace-nowrap text-neutral-700">
          シナリオ制作
          <span class="font-serif-it text-sky-500 text-base md:text-xl">scenario</span>
          <span class="w-1 h-1 rounded-full bg-neutral-300"></span>
          サークル運営補助
          <span class="font-serif-it text-sky-500 text-base md:text-xl">management</span>
          <span class="w-1 h-1 rounded-full bg-neutral-300"></span>
        </span>
      ))}
    </div>
  </section>

  <!-- ====== INDEX OF SERVICES ====== -->
  <section class="px-5 md:px-10 py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-y-6 gap-x-6 mb-16 md:mb-24">
      <div class="md:col-span-3">
        <p class="font-mono text-xs uppercase tracking-widest text-neutral-500 mb-2 reveal">— 01 / Services</p>
      </div>
      <div class="md:col-span-9 reveal reveal-d1">
        <h2 class="font-display text-5xl md:text-7xl lg:text-8xl font-medium leading-[0.95] tracking-tight jp-balance">
          メインは、<span class="font-serif-it text-sky-500">2つ</span>
        </h2>
      </div>
    </div>

    <div class="space-y-px bg-neutral-200">
      <!-- Service 1 -->
      <a href="/services#scenario" class="group block bg-[var(--color-paper)] hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-500 reveal">
        <div class="px-2 md:px-8 py-8 md:py-12 grid grid-cols-12 gap-4 items-center">
          <span class="col-span-2 big-number text-3xl md:text-5xl text-neutral-300 group-hover:text-sky-500 transition-colors">01</span>
          <div class="col-span-10 md:col-span-7">
            <h3 class="font-display text-2xl md:text-4xl font-medium mb-2">
              シナリオ制作
              <span class="font-serif-it text-neutral-400 text-lg md:text-2xl">— Scenario writing</span>
            </h3>
            <p class="text-sm md:text-base text-neutral-500 group-hover:text-neutral-300 transition-colors max-w-2xl">
              DLSite成人男性向け音声作品の台本を、ジャンル・キャラクター・尺感に合わせて執筆。声優さんが読みやすい構成で。
            </p>
          </div>
          <div class="hidden md:flex col-span-3 justify-end">
            <span class="font-mono text-xs uppercase tracking-widest opacity-60 group-hover:opacity-100 transition-opacity inline-flex items-center gap-2">
              View more
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Service 2 (MAIN) -->
      <a href="/services#management" class="group block bg-[var(--color-paper)] hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-500 reveal reveal-d1">
        <div class="px-2 md:px-8 py-8 md:py-12 grid grid-cols-12 gap-4 items-center">
          <span class="col-span-2 big-number text-3xl md:text-5xl text-neutral-300 group-hover:text-sky-500 transition-colors">02</span>
          <div class="col-span-10 md:col-span-7">
            <h3 class="font-display text-2xl md:text-4xl font-medium mb-2 flex flex-wrap items-baseline gap-x-3">
              サークル運営補助
              <span class="text-xs md:text-sm font-sans font-normal bg-sky-500 text-white px-2 py-0.5 rounded-full">MAIN</span>
            </h3>
            <p class="text-sm md:text-base text-neutral-500 group-hover:text-neutral-300 transition-colors max-w-2xl">
              マネジメント・タスク管理・関係者への連絡代行。サークル主の作業負担を肩代わりする、いちばん中核のサービス。
            </p>
          </div>
          <div class="hidden md:flex col-span-3 justify-end">
            <span class="font-mono text-xs uppercase tracking-widest opacity-60 group-hover:opacity-100 transition-opacity inline-flex items-center gap-2">
              View more
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>
    </div>

    <!-- Add-on note -->
    <div class="mt-10 md:mt-16 max-w-3xl mx-auto md:mx-0 md:ml-auto reveal reveal-d2">
      <p class="text-xs md:text-sm text-neutral-500 leading-relaxed border-l-2 border-neutral-300 pl-4">
        <span class="font-mono uppercase tracking-widest text-neutral-400 mr-2">+</span>
        運営サポートやマネジメント代行を継続してご依頼いただいているサークル様・個人声優様には、
        確定申告補助をプラスサポートとして別途お引き受けしています。
      </p>
    </div>
  </section>

  <!-- ====== STATS / NUMBERS ====== -->
  <section class="bg-[var(--color-ink)] text-[var(--color-paper)] py-24 md:py-32 px-5 md:px-10 relative overflow-hidden">
    <div class="grain absolute inset-0"></div>
    <div class="relative">
      <p class="font-mono text-xs uppercase tracking-widest text-sky-400 mb-12 reveal">— 実績</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-12 gap-x-6">
        <div class="reveal">
          <p class="big-number text-6xl md:text-8xl font-medium text-sky-400">50+</p>
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-400 mt-3">個人事業主の確定申告サポート経験</p>
        </div>
        <div class="reveal reveal-d1">
          <p class="big-number text-6xl md:text-8xl font-medium">∞</p>
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-400 mt-3">担当作品（更新中）</p>
        </div>
        <div class="reveal reveal-d2">
          <p class="big-number text-6xl md:text-8xl font-medium">24h</p>
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-400 mt-3">初回返信目安</p>
        </div>
        <div class="reveal reveal-d3">
          <p class="big-number text-6xl md:text-8xl font-medium">2<span class="font-serif-it text-sky-400">+</span></p>
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-400 mt-3">主要サービス領域</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PORTFOLIO PEEK ====== -->
  {latestWorks.length > 0 && (
    <section class="px-5 md:px-10 py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-y-6 gap-x-6 mb-12 md:mb-16">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-500 mb-2 reveal">— 02 / Portfolio</p>
        </div>
        <div class="md:col-span-9 reveal reveal-d1 flex flex-wrap items-end justify-between gap-4">
          <h2 class="font-display text-5xl md:text-7xl font-medium leading-[0.95] tracking-tight jp-balance">
            担当作品
          </h2>
          <a href="/portfolio" class="link-underline font-mono text-xs uppercase tracking-widest">すべて見る →</a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200">
        {latestWorks.map((work, i) => (
          <a
            href={work.data.dlsiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class={`group bg-[var(--color-paper)] p-8 md:p-12 hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-500 reveal reveal-d${i + 1}`}
          >
            <div class="flex items-start justify-between mb-12">
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-400 group-hover:text-sky-400 transition-colors">
                — {String(i + 1).padStart(2, '0')} / {work.data.circle}
              </span>
              <span class="font-mono text-xs text-neutral-400 group-hover:text-neutral-400 transition-colors">
                {work.data.releaseDate.getFullYear()}
              </span>
            </div>
            <h3 class="font-display text-2xl md:text-4xl font-medium leading-tight mb-6">
              {work.data.title}
            </h3>
            <p class="text-sm text-neutral-500 group-hover:text-neutral-300 transition-colors leading-relaxed line-clamp-3">
              {work.data.excerpt}
            </p>
            <div class="mt-12 inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest">
              DLSite →
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ====== JOURNAL ====== -->
  {latestPosts.length > 0 && (
    <section class="px-5 md:px-10 py-24 md:py-32 border-t border-neutral-200">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-y-6 gap-x-6 mb-12 md:mb-16">
        <div class="md:col-span-3">
          <p class="font-mono text-xs uppercase tracking-widest text-neutral-500 mb-2 reveal">— 03 / Blog</p>
        </div>
        <div class="md:col-span-9 reveal reveal-d1 flex flex-wrap items-end justify-between gap-4">
          <h2 class="font-display text-5xl md:text-7xl font-medium leading-[0.95] tracking-tight jp-balance">
            最新の記事
          </h2>
          <a href="/blog" class="link-underline font-mono text-xs uppercase tracking-widest">すべて見る →</a>
        </div>
      </div>

      <div class="border-t border-neutral-200">
        {latestPosts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class={`group block border-b border-neutral-200 py-8 md:py-10 grid grid-cols-12 gap-4 items-center reveal reveal-d${i + 1}`}
          >
            <span class="col-span-2 md:col-span-1 font-mono text-xs text-neutral-400">{String(i + 1).padStart(2, '0')}</span>
            <div class="col-span-10 md:col-span-7">
              <p class="font-mono text-[10px] uppercase tracking-widest text-sky-600 mb-2">{post.data.category}</p>
              <h3 class="font-display text-2xl md:text-3xl font-medium leading-snug group-hover:text-sky-600 transition-colors">
                {post.data.title}
              </h3>
            </div>
            <div class="hidden md:block md:col-span-3 text-sm text-neutral-500">
              {post.data.description}
            </div>
            <div class="hidden md:block md:col-span-1 text-right font-mono text-xs text-neutral-400">
              {post.data.pubDate.toLocaleDateString('ja-JP', { year: '2-digit', month: '2-digit', day: '2-digit' })}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}


</Layout>
