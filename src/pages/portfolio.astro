---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Portfolio" description="miketone シナリオ担当作品一覧">

  <div class="max-w-6xl mx-auto px-6 py-20">

    <div class="text-center mb-16 fade-in">
      <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-2">Portfolio</p>
      <h1 class="text-4xl font-bold text-slate-900 mb-4">担当作品</h1>
      <p class="text-slate-500">シナリオを担当した音声作品の一覧です。</p>
    </div>

    {works.length === 0 ? (
      <div class="text-center py-24 text-slate-400">
        <p>作品を準備中です。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {works.map((work, i) => (
          <a
            href={work.data.dlsiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class={`group block bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300 hover:-translate-y-1 fade-in fade-in-delay-${(i % 4) + 1}`}
          >
            <div class="aspect-square overflow-hidden bg-slate-100">
              <img
                src={work.data.thumbnail}
                alt={work.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-4">
              <p class="text-xs text-sky-500 font-medium mb-1">{work.data.circle}</p>
              <h2 class="text-sm font-bold text-slate-900 line-clamp-2 mb-2">{work.data.title}</h2>
              <p class="text-xs text-slate-500 line-clamp-3 leading-relaxed">{work.data.excerpt}</p>
              <div class="flex items-center justify-between mt-3">
                <span class="text-xs text-slate-400">{work.data.releaseDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short' })}</span>
                <span class="text-xs text-sky-500 font-medium group-hover:underline">DLSite →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</Layout>
