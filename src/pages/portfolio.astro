---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Portfolio" description="miketone — シナリオ担当作品の一覧">

  <!-- Hero -->
  <section class="px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="flex justify-between items-center mb-12 md:mb-20 text-xs font-mono uppercase tracking-widest text-neutral-500">
      <span>— 02 / Portfolio</span>
      <span>{works.length} works</span>
    </div>
    <h1 class="font-display text-[15vw] md:text-[11vw] lg:text-[9rem] font-medium leading-[0.92] tracking-tight mb-8">
      <span class="mask-reveal block"><span>担当</span></span>
      <span class="mask-reveal block"><span><span class="font-serif-it text-sky-500">作品</span></span></span>
    </h1>
    <div class="md:max-w-2xl md:ml-auto reveal reveal-d2">
      <p class="text-neutral-700 text-base md:text-lg leading-relaxed jp-balance">
        これまでシナリオを担当した音声作品の一覧です。<br class="hidden md:inline" />気になる作品はDLSiteのページへ。
      </p>
    </div>
  </section>

  {works.length === 0 ? (
    <div class="px-5 md:px-10 py-24 text-center">
      <p class="font-display text-4xl text-neutral-400 font-serif-it">準備中 —</p>
    </div>
  ) : (
    <!-- Index style listing -->
    <section class="border-t border-[var(--color-ink)]">
      {works.map((work, i) => (
        <a
          href={work.data.dlsiteUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={`group block border-b border-neutral-200 hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors duration-500 reveal reveal-d${(i % 4) + 1}`}
        >
          <div class="px-5 md:px-10 py-8 md:py-12 grid grid-cols-12 gap-x-4 gap-y-3 items-center">
            <span class="col-span-2 md:col-span-1 font-mono text-xs md:text-sm text-neutral-400 group-hover:text-sky-400 transition-colors">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="col-span-10 md:col-span-6">
              <p class="font-mono text-[10px] uppercase tracking-widest text-sky-600 group-hover:text-sky-400 transition-colors mb-2">
                {work.data.circle}
              </p>
              <h2 class="font-display text-2xl md:text-4xl font-medium leading-tight">
                {work.data.title}
              </h2>
            </div>
            <p class="hidden md:block col-span-3 text-sm text-neutral-500 group-hover:text-neutral-300 transition-colors leading-relaxed line-clamp-2">
              {work.data.excerpt}
            </p>
            <div class="col-span-12 md:col-span-2 flex md:justify-end items-center gap-3">
              <span class="font-mono text-xs text-neutral-400 group-hover:text-neutral-300 transition-colors">
                {work.data.releaseDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit' })}
              </span>
              <span class="font-mono text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity inline-flex items-center gap-1">
                DLSite →
              </span>
            </div>
          </div>
          <!-- Mobile excerpt -->
          <p class="md:hidden px-5 pb-6 -mt-2 text-sm text-neutral-500 group-hover:text-neutral-300 transition-colors">
            {work.data.excerpt}
          </p>
        </a>
      ))}
    </section>
  )}

  <!-- CTA -->
  <section class="px-5 md:px-10 py-24 md:py-32 border-t border-neutral-200">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
      <div class="md:col-span-8 reveal">
        <p class="font-mono text-xs uppercase tracking-widest text-neutral-500 mb-4">— 次のプロジェクト</p>
        <p class="font-display text-3xl md:text-5xl font-medium leading-tight jp-balance">
          あなたの作品も、ここに
        </p>
      </div>
      <div class="md:col-span-4 md:text-right reveal reveal-d1">
        <a
          href="/contact"
          class="inline-flex items-center gap-3 px-7 py-3.5 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-full hover:bg-sky-500 transition-colors duration-300 group"
        >
          シナリオを依頼する
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
